/NOTES.md

# Per-machine signing config, generated by scripts/setup-signing.sh
Local.xcconfig

# Xcode — the .xcodeproj is regenerated by xcodegen from Project.yml.
# Don't commit it; everyone regenerates after pull to avoid pbxproj merge conflicts.
AgentNotch.xcodeproj/
# Numbered dupes Finder creates when Xcode opens during an xcodegen regen.
AgentNotch [0-9]*.xcodeproj/
*.xcuserstate
xcuserdata/
DerivedData/
build/
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/

# Swift Package Manager
.swiftpm/
.build/
Package.resolved

# macOS
.DS_Store

# Local secrets — bundled at build time, never committed.
.env
# Legacy secrets dir from before `.env` consolidation (origin commit 461f0c0
# removed the tracked Config/ dir but local copies with keys can linger).
# Belt-and-suspenders so a stray `git add -A` never re-stages them.
Config/
Config/agentnotch.env

# ArshanTesting sandbox
ArshanTesting/.env
ArshanTesting/node_modules/
ArshanTesting/.npm-cache/
ArshanTesting/dist/
ArshanTesting/coverage/
ArshanTesting/test-results/
ArshanTesting/playwright-report/
ArshanTesting/fixtures/private/
ArshanTesting/memory/private/
ArshanTesting/memory/cache/*.json
ArshanTesting/memory/preprocessed/
.gstack/

landing/node_modules/
landing/.next/
landing/out/
landing/.vercel/
.claude/worktrees/

# Eval harness runtime outputs
tests/eval/results/*
!tests/eval/results/.gitkeep
tools/MercurySpike/.build/
tools/MercurySpike/.swiftpm/
tools/MercurySpike/Package.resolved
