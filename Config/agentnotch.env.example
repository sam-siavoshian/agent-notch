# Agent in the Notch — local secrets.
# Copy this file to Config/agentnotch.env and fill in your keys.
# The real file is gitignored. Anything here is loaded into the process
# environment at launch via Core/EnvLoader.swift, so every consumer
# (Secrets, Gemini, demo prompt) sees the same values.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional. If set and the mic produced nothing (or Whisper is still
# initializing), VoiceRecordingService uses this as the transcript.
ANTHROPIC_NOTCH_DEMO_PROMPT=
